# Required core keys (existing project requirements)
DATAFORSEO_USERNAME=you@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
PERPLEXITY_API_KEY=your-perplexity-key
JINA_API_KEY=your-jina-key

# Diagnostic Step 1 integrations
FIRECRAWL_API_KEY=your-firecrawl-key
XAI_API_KEY=your-xai-key
GOOGLE_API_KEY=your-google-key

# Optional if using Vercel AI Gateway for Gemini adapter
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/ai

# Optional app URL (used in share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional Directus CMS runtime
DIRECTUS_URL=
DIRECTUS_TOKEN=

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=5hi8oae6
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-12-30

# Optional local MCP/tooling secrets
DIRECTUS_MCP_TOKEN=
NEON_API_KEY=

# Database URLs
# DATABASE_URL: Admin connection (neondb_owner) - bypasses RLS, for migrations/webhooks/admin
# DATABASE_AUTHENTICATED_URL: RLS-enforced connection (authenticated_backend) - for user-facing API routes
# If DATABASE_AUTHENTICATED_URL is not set, falls back to DATABASE_URL (RLS still enforced if role has FORCE ROW LEVEL SECURITY)
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_AUTHENTICATED_URL=postgresql://authenticated_backend:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Step 1 runtime tuning
DIAGNOSTIC_CACHE_TTL_MINUTES=30
DIAGNOSTIC_HTTP_TIMEOUT_MS=15000
DIAGNOSTIC_RETRY_ATTEMPTS=2
DIAGNOSTIC_KEYWORD_MIN_VOLUME=100

# Gemini adapter mode: auto | gateway | direct
DIAGNOSTIC_GEMINI_MODE=auto
DIAGNOSTIC_GEMINI_GATEWAY_MODEL=google/gemini-2.5-flash
DIAGNOSTIC_GEMINI_DIRECT_MODEL=gemini-2.0-flash

# Other model IDs
DIAGNOSTIC_PERPLEXITY_MODEL=sonar
DIAGNOSTIC_GROK_MODEL=grok-2-latest
