# Required core keys (existing project requirements)
# For local development, run: pnpm run validate:env:local
DATAFORSEO_USERNAME=you@example.com
DATAFORSEO_PASSWORD=your-dataforseo-password
PERPLEXITY_API_KEY=your-perplexity-key
JINA_API_KEY=your-jina-key

# Diagnostic Step 1 integrations
FIRECRAWL_API_KEY=your-firecrawl-key
XAI_API_KEY=your-xai-key
GOOGLE_API_KEY=your-google-key

# Optional if using Vercel AI Gateway for Gemini adapter
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1/ai

# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional GEO / AEO mode and weekly research configuration
CRON_SECRET=
GEO_ENABLED_ENGINES=chatgpt,perplexity,google_ai_overview
GEO_COMPETITORS=
GEO_DEFAULT_TOPICS=AI visibility,answer engine optimization,Google AI Overview citations

# Elmo / geomode API (Bearer token must match ADMIN_API_KEYS on the Elmo instance)
ELMO_API_URL=https://geo.flowintent.com
ELMO_API_KEY=

# Cloudflare Tunnel (VPS geomode stack — Zero Trust > Tunnels > Install connector token)
CLOUDFLARE_TUNNEL_TOKEN=

# geomode companion read API (Cloudflare Access service token)
GEO_API_URL=https://geo-api.flowintent.com
GEO_API_CLIENT_ID=
GEO_API_KEY=
GEO_TRACKING_BRAND=

# Local Vultr deploy helpers (never commit real values)
VULTR_API_KEY=
VULTR_GEOMODE_INSTANCE_ID=c69492ff-272a-4d42-8925-94899edb2f10
VULTR_GEOMODE_HOST=45.76.118.244
WEEKLY_RESEARCH_MODEL=openai/gpt-5.5
WEEKLY_RESEARCH_FALLBACK_MODEL=openai/gpt-5.4
SCRAPINGBEE_API_KEY=
EXA_API_KEY=

# Optional app URL (used in share links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Polar billing
POLAR_ACCESS_TOKEN=your-polar-access-token
POLAR_PRODUCT_ID=your-polar-product-id
POLAR_WEBHOOK_SECRET=your-polar-webhook-signing-secret
POLAR_SUCCESS_URL=http://localhost:3000/dashboard?billing=success
POLAR_RETURN_URL=http://localhost:3000/prices

# Webflow CMS
WEBFLOW_API_TOKEN=
WEBFLOW_BLOG_ID=
WEBFLOW_CASESTUDIES_ID=

# Optional local MCP/tooling secrets
NEON_API_KEY=

# Database URLs
# DATABASE_URL: Admin connection (neondb_owner) - bypasses RLS, for migrations/webhooks/admin
# DATABASE_AUTHENTICATED_URL: RLS-enforced connection (authenticated_backend) - for user-facing API routes
# If DATABASE_AUTHENTICATED_URL is not set, falls back to DATABASE_URL (RLS still enforced if role has FORCE ROW LEVEL SECURITY)
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_AUTHENTICATED_URL=postgresql://authenticated_backend:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Step 1 runtime tuning
DIAGNOSTIC_CACHE_TTL_MINUTES=30
DIAGNOSTIC_HTTP_TIMEOUT_MS=15000
DIAGNOSTIC_RETRY_ATTEMPTS=2
DIAGNOSTIC_KEYWORD_MIN_VOLUME=100

# Gemini adapter mode: auto | gateway | direct
DIAGNOSTIC_GEMINI_MODE=auto
DIAGNOSTIC_GEMINI_GATEWAY_MODEL=google/gemini-2.5-flash
DIAGNOSTIC_GEMINI_DIRECT_MODEL=gemini-2.0-flash

# Other model IDs
DIAGNOSTIC_PERPLEXITY_MODEL=sonar
DIAGNOSTIC_GROK_MODEL=grok-2-latest
