{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "directus-mcp": {
      "type": "remote",
      "url": "https://massive-smilodon.pikapod.net/mcp",
      "headers": {
        "Authorization": "Bearer CcQvJt2nUAC40RA9Si9--u5Ze79KaL-a"
},
      "enabled": true
    },
    "auggie": {
      "type": "local",
      "command": [
        "auggie",
        "--mcp",
        "--mcp-auto-workspace"
      ],
      "enabled": true
    },
    "dataforseo": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "dataforseo-mcp-server"
      ],
      "environment": {
        "DATAFORSEO_USERNAME": "${DATAFORSEO_USERNAME}",
        "DATAFORSEO_PASSWORD": "${DATAFORSEO_PASSWORD}",
        "DATAFORSEO_SIMPLE_FILTER": "true"
      },
      "enabled": true
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "environment": {
        "FIRECRAWL_API_KEY": "${FIRECRAWL_API_KEY}"
      },
      "enabled": true
    },
    "perplexity": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@perplexity-ai/mcp-server"
      ],
      "environment": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      },
      "enabled": true
    },
    "directus": {
      "type": "remote",
      "url": "https://massive-smilodon.pikapod.net/mcp?access_token=CcQvJt2nUAC40RA9Si9--u5Ze79KaL-a",
      "enabled": true
    },
    "neon": {
      "type": "remote",
      "url": "https://mcp.neon.tech/mcp",
      "headers": {
